# Copia como `.env` (local) y configura las mismas variables en Render.
# NUNCA subas el .env real a GitHub.

SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key_secreta
GEMINI_API_KEY=tu_gemini_api_key
TELEGRAM_BOT_TOKEN=token_de_botfather

# Solo en producción (Render). Si está vacío, el bot corre en long polling (local).
# Ej: https://red-de-esperanza-bot.onrender.com
PUBLIC_URL=
# Puerto del servidor de webhook (Render lo inyecta en PORT).
PORT=3000
