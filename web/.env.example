# Copia este archivo como `.env` y rellena con tus valores de Supabase.
# (Project Settings → API). NUNCA subas el .env real a GitHub.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_public_key

# (Opcional) Clave de Google Maps para geocodificar direcciones con precisión
# (números de casa). Si no se pone, la app usa OpenStreetMap como respaldo.
# IMPORTANTE: restríngela por dominio (HTTP referrers) en Google Cloud, porque
# queda visible en el navegador (es normal en claves de Maps para web).
VITE_GOOGLE_MAPS_KEY=tu_clave_de_google_maps
